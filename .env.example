# Postgres connection (docker-compose maps host port 5433; use Neon/Supabase URL in prod)
DATABASE_URL="postgresql://cruxai:cruxai@localhost:5433/cruxai?schema=public"

# Claude API key — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Models (override if needed)
MODEL_SUMMARY="claude-opus-4-8"
MODEL_QUIZ="claude-opus-4-8"
MODEL_GRADE="claude-sonnet-4-6"

# Server
PORT=4000
# Public base URL of THIS API (used to build local presigned upload URLs)
PUBLIC_API_URL="http://localhost:4000"
# Comma-separated allowed origins for CORS (web app URL)
CORS_ORIGIN="http://localhost:3000"

# Object storage for uploads. "local" writes to disk (dev, no creds needed);
# "s3" presigns direct browser uploads to any S3-compatible store.
STORAGE_DRIVER="local"
LOCAL_STORAGE_DIR=".uploads"
# --- only when STORAGE_DRIVER="s3" (AWS S3, Cloudflare R2, MinIO, Backblaze) ---
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""                  # e.g. https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_FORCE_PATH_STYLE="false"     # "true" for MinIO / path-style endpoints
# NOTE: the S3 bucket needs CORS allowing PUT from CORS_ORIGIN.

# Background jobs (pg-boss) reuse DATABASE_URL — no extra config needed.

# Google reCAPTCHA v3 (leave blank to DISABLE captcha in dev).
# Get keys at https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET=""
RECAPTCHA_MIN_SCORE="0.5"
RECAPTCHA_VERIFY_URL="https://www.google.com/recaptcha/api/siteverify"

# Secret for signing session JWTs (use a long random string in prod)
JWT_SECRET="change-me"

# DEMO ONLY — simulated growing stats + online count for local presentations.
# Keep this false/unset in production so all metrics stay real.
DEMO_MODE="false"

# Premium audio (optional). Leave AUDIO_PROVIDER blank to use free browser TTS.
AUDIO_PROVIDER=""               # "" | "elevenlabs"
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="EXAVITQu4vr4xnSDxMaL"
ELEVENLABS_API_URL="https://api.elevenlabs.io/v1/text-to-speech"
ELEVENLABS_MODEL="eleven_multilingual_v2"
